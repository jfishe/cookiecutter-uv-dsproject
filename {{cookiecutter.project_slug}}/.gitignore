# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ----- uv -----
.venv/
uv.lock

# ----- Testing -----
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ----- mypy -----
.mypy_cache/

# ----- Ruff -----
.ruff_cache/

# ----- Jupyter -----
.ipynb_checkpoints/

# ----- Docs -----
docs/apidocs/
docs/_build/

# ----- Data (keep structure, ignore large files) -----
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep

# ----- Models -----
models/*
!models/.gitkeep

# ----- IDE -----
.idea/
.vscode/
*.swp
*.swo
*~

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Docker -----
*.tar

